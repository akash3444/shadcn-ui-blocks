{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "empty-state-03",
  "title": "Empty State 03",
  "description": "A simple empty state block",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "tabs",
    "button"
  ],
  "files": [
    {
      "path": "src/registry/blocks/base/empty-state-03/components/empty-state.tsx",
      "content": "import {\n  BadgeDollarSign,\n  CreditCard,\n  ImportIcon,\n  PlusIcon,\n  Receipt,\n} from \"lucide-react\";\nimport { Button } from \"@/registry/ui/base/button\";\nimport {\n  Empty,\n  EmptyContent,\n  EmptyDescription,\n  EmptyHeader,\n  EmptyMedia,\n  EmptyTitle,\n} from \"@/registry/ui/base/empty\";\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from \"@/registry/ui/base/tabs\";\nimport { cn } from \"@/lib/utils\";\n\nexport default function EmptyState() {\n  return (\n    <div className=\"px-6 py-10\">\n      <div className=\"mx-auto max-w-lg\">\n        <Tabs defaultValue=\"invoices\">\n          <TabsList\n            className={cn(\n              \"mb-3 bg-transparent p-0\",\n              \"*:px-3 *:text-muted-foreground *:data-[state=active]:bg-muted *:data-[state=active]:text-foreground *:data-[state=active]:shadow-none\"\n            )}\n          >\n            <TabsTrigger value=\"invoices\">\n              <Receipt /> Invoices\n            </TabsTrigger>\n            <TabsTrigger value=\"payments\">\n              <BadgeDollarSign /> Payments\n            </TabsTrigger>\n            <TabsTrigger value=\"subscriptions\">\n              <CreditCard /> Subscriptions\n            </TabsTrigger>\n          </TabsList>\n\n          <TabsContent value=\"invoices\">\n            <Empty className=\"rounded-xl border bg-muted/30 py-12\">\n              <EmptyHeader>\n                <EmptyMedia variant=\"icon\">\n                  <Receipt />\n                </EmptyMedia>\n                <EmptyTitle>No Invoices Yet</EmptyTitle>\n                <EmptyDescription>\n                  You haven&apos;t created any invoices yet. Get started by\n                  creating your first invoice.\n                </EmptyDescription>\n              </EmptyHeader>\n              <EmptyContent>\n                <div className=\"flex flex-wrap gap-2 *:mx-auto\">\n                  <Button>\n                    <PlusIcon /> Create Invoice\n                  </Button>\n                  <Button variant=\"outline\">\n                    <ImportIcon /> Import Invoice\n                  </Button>\n                </div>\n              </EmptyContent>\n            </Empty>\n          </TabsContent>\n\n          <TabsContent value=\"payments\">\n            <Empty className=\"rounded-xl border bg-muted/30 py-12\">\n              <EmptyHeader>\n                <EmptyMedia variant=\"icon\">\n                  <BadgeDollarSign />\n                </EmptyMedia>\n                <EmptyTitle>No Payments Yet</EmptyTitle>\n                <EmptyDescription>\n                  You haven&apos;t received any payments yet. Payments will\n                  appear here once your invoices are paid.\n                </EmptyDescription>\n              </EmptyHeader>\n              <EmptyContent>\n                <div className=\"flex flex-wrap gap-2 *:mx-auto\">\n                  <Button>\n                    <PlusIcon /> Record Payment\n                  </Button>\n                </div>\n              </EmptyContent>\n            </Empty>\n          </TabsContent>\n\n          <TabsContent value=\"subscriptions\">\n            <Empty className=\"rounded-xl border bg-muted/30 py-12\">\n              <EmptyHeader>\n                <EmptyMedia variant=\"icon\">\n                  <CreditCard />\n                </EmptyMedia>\n                <EmptyTitle>No Subscriptions Yet</EmptyTitle>\n                <EmptyDescription>\n                  You don&apos;t have any active subscriptions. Create recurring\n                  billing plans for your customers.\n                </EmptyDescription>\n              </EmptyHeader>\n              <EmptyContent>\n                <div className=\"flex flex-wrap gap-2 *:mx-auto\">\n                  <Button>\n                    <PlusIcon /> Create Subscription\n                  </Button>\n                </div>\n              </EmptyContent>\n            </Empty>\n          </TabsContent>\n        </Tabs>\n      </div>\n    </div>\n  );\n}\n",
      "type": "registry:component"
    }
  ],
  "type": "registry:block"
}