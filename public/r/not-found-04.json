{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "not-found-04",
  "title": "Not Found 04",
  "description": "A 404 not found block with a search input",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "button",
    "input"
  ],
  "files": [
    {
      "path": "src/registry/blocks/not-found-04/components/not-found.tsx",
      "content": "import { ArrowLeftIcon, SearchIcon, SearchXIcon } from \"lucide-react\";\nimport Link from \"next/link\";\nimport { Button } from \"@/components/ui/button\";\nimport { Input } from \"@/components/ui/input\";\n\nexport default function NotFound() {\n  return (\n    <div className=\"flex min-h-screen flex-col items-center justify-center px-6 text-center\">\n      <div className=\"flex size-12 items-center justify-center rounded-2xl border bg-muted\">\n        <SearchXIcon className=\"size-6 text-muted-foreground\" />\n      </div>\n      <h1 className=\"mt-6 font-medium text-4xl/none tracking-tight\">\n        Page not found\n      </h1>\n      <p className=\"mt-4 max-w-sm text-pretty text-muted-foreground\">\n        Can&apos;t find what you&apos;re looking for?\n        Try&nbsp;searching&nbsp;below.\n      </p>\n      <form action=\"/search\" className=\"mt-8 w-full max-w-sm\">\n        <div className=\"relative\">\n          <SearchIcon className=\"absolute top-1/2 left-3 size-4 -translate-y-1/2 text-muted-foreground\" />\n          <Input\n            className=\"pl-9\"\n            name=\"q\"\n            placeholder=\"Search...\"\n            type=\"search\"\n          />\n        </div>\n        <Button className=\"mt-3 w-full\" type=\"submit\">\n          Search\n        </Button>\n      </form>\n      <Button asChild className=\"mt-6\" variant=\"link\">\n        <Link\n          className=\"underline underline-offset-4 hover:text-foreground\"\n          href=\"#\"\n        >\n          <ArrowLeftIcon /> Go back home\n        </Link>\n      </Button>\n    </div>\n  );\n}\n",
      "type": "registry:component"
    }
  ],
  "type": "registry:block"
}